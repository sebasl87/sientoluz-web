# ── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # solo servidor, nunca NEXT_PUBLIC_

# ── Mercado Pago ────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-...
MP_WEBHOOK_SECRET=...                   # Panel MP → Webhooks → clave secreta

# ── Sitio ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://sientoluz.com

# ── n8n (Fase 3) ────────────────────────────────────────────
N8N_WEBHOOK_URL=https://n8n.tudominio.com/webhook/sientoluz-entrega
N8N_WEBHOOK_TOKEN=un-token-largo-y-random

# ── Resend (Envio mails) ────────────────────────────────────────────
RESEND_API_KEY         resend.com → API Keys
EMAIL_FROM             "SientoLuz <hola@sientoluz.com>"
                         (requiere dominio verificado en Resend: SPF+DKIM)
# ── Datos de transferencia (se muestran al cliente) ─────────
NEXT_PUBLIC_TRANSF_TITULAR=Nombre Apellido
NEXT_PUBLIC_TRANSF_CBU=0000000000000000000000
NEXT_PUBLIC_TRANSF_ALIAS=sientoluz.mp
NEXT_PUBLIC_WHATSAPP=5492944000000
